rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /reports/{uid}/{allPaths=**} {
      allow write: if uid.matches('^guest_[a-z0-9]{8}$')
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('(image|audio)/.*');
      allow read: if true;
    }
  }
}